diff --git a/docker-entrypoint.sh b/docker-entrypoint.sh
new file mode 100755
index 0000000..7af167e
--- /dev/null
+++ b/docker-entrypoint.sh
@@ -0,0 +1,25 @@
+#!/bin/sh
+set -eu
+
+PAPERCLIP_HOME="${PAPERCLIP_HOME:-/paperclip}"
+PAPERCLIP_RUNTIME_UID="${PAPERCLIP_RUNTIME_UID:-1000}"
+PAPERCLIP_RUNTIME_GID="${PAPERCLIP_RUNTIME_GID:-1000}"
+
+mkdir -p "${PAPERCLIP_HOME}"
+
+if [ "${PAPERCLIP_FIX_OWNERSHIP:-1}" = "1" ]; then
+  # Best-effort fix for host bind-mount ownership mismatches.
+  chown -R "${PAPERCLIP_RUNTIME_UID}:${PAPERCLIP_RUNTIME_GID}" "${PAPERCLIP_HOME}" 2>/dev/null || true
+fi
+
+if ! gosu "${PAPERCLIP_RUNTIME_UID}:${PAPERCLIP_RUNTIME_GID}" sh -ec \
+  "mkdir -p \"${PAPERCLIP_HOME}/instances/default/logs\" \"${PAPERCLIP_HOME}/instances/default/db\""; then
+  cat >&2 <<EOM
+ERROR: ${PAPERCLIP_HOME} is not writable by uid ${PAPERCLIP_RUNTIME_UID}.
+Fix with:
+  chown -R ${PAPERCLIP_RUNTIME_UID}:${PAPERCLIP_RUNTIME_GID} <host-path-mounted-at-${PAPERCLIP_HOME}>
+EOM
+  exit 1
+fi
+
+exec gosu "${PAPERCLIP_RUNTIME_UID}:${PAPERCLIP_RUNTIME_GID}" "$@"
